<Application x:Class="SkythornLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="FantasyFont">pack://siteoforigin:,,,/Assets/Fonts/Harrington.ttf#Harrington</FontFamily>

        <Style x:Key="DynamicValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="MainMenuProfilePanelValueText" TargetType="TextBlock" BasedOn="{StaticResource DynamicValueText}">
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="FantasyHeadingText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F0E6CC"/>
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="24"/>
        </Style>

        <Style x:Key="FantasyBodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A89878"/>
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="SubWindowHeadingText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F0E6CC"/>
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>

        <Style x:Key="SubWindowField" TargetType="TextBox">
            <Setter Property="Background" Value="#990E0A08"/>
            <Setter Property="Foreground" Value="#F0E6CC"/>
            <Setter Property="BorderBrush" Value="#806B5A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="SubWindowPassword" TargetType="PasswordBox">
            <Setter Property="Background" Value="#990E0A08"/>
            <Setter Property="Foreground" Value="#F0E6CC"/>
            <Setter Property="BorderBrush" Value="#806B5A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="SubWindowList" TargetType="ListBox">
            <Setter Property="Background" Value="#990E0A08"/>
            <Setter Property="Foreground" Value="#F0E6CC"/>
            <Setter Property="BorderBrush" Value="#806B5A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="SubWindowCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#990E0A08"/>
            <Setter Property="Foreground" Value="#F0E6CC"/>
            <Setter Property="BorderBrush" Value="#806B5A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="SubWindowCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0E6CC"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="SubWindowSecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#806B5A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFEE00"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E6D600"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubWindowPrimaryButton" TargetType="Button" BasedOn="{StaticResource SubWindowSecondaryButton}"/>

        <Style x:Key="SubWindowCancelButton" TargetType="Button" BasedOn="{StaticResource SubWindowSecondaryButton}"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
    </Application.Resources>
</Application>
